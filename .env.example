# ---------------------------------------------------------------------------
# Mem Palace — environment template
# Copy to `.env` and fill in. Never commit `.env`.
# ---------------------------------------------------------------------------

# --- Supabase (Project Settings → API in supabase.com dashboard) ------------
# Public values (safe to expose to the browser):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side mirrors (FastAPI reads these). Same values, different names so
# we never accidentally ship the anon key bundled in a server-only context.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Server-only. Bypasses RLS — use ONLY for system jobs (ingestion, agents).
SUPABASE_SERVICE_ROLE_KEY=

# Used by FastAPI to verify JWTs issued by Supabase Auth.
# Find under: Project Settings → API → JWT Secret.
SUPABASE_JWT_SECRET=

# --- OpenAI -----------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# --- App wiring -------------------------------------------------------------
# Web -> API base URL. Inside docker compose, services reach each other by
# service name; from the browser they use localhost. We use the browser-facing
# URL here because lib/api.ts runs client-side.
NEXT_PUBLIC_API_URL=http://localhost:8000

# CORS: comma-separated origins FastAPI accepts.
API_CORS_ORIGINS=http://localhost:3000
